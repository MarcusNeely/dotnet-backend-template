{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Secret": "SET_IN_USER_SECRETS_OR_ENVIRONMENT_VARIABLE",
    "Issuer": "https://api.example.com",
    "Audience": "https://example.com",
    "ExpiresInMinutes": 15,
    "RefreshExpiryDays": 7
  }
}
